# Configuración de Supabase
VITE_SUPABASE_URL=https://xyz.supabase.co
VITE_SUPABASE_ANON_KEY=public-anon-key

# API de resultados (BeSoccer o similar)
VITE_BESOCCER_API_KEY=your-besoccer-api-key

# API de football-data.org
# Local: Vite lee FOOTBALL_API_KEY desde el proxy de desarrollo.
# Deploy: configurar FOOTBALL_API_KEY como variable server-side.
FOOTBALL_API_KEY=your-football-api-key
